{
  "name": "Resume Builder API",
  "build": {
    "context": "..",
    "dockerfile": "../Dockerfile.dev.api"
  },
  "workspaceFolder": "/app",
  "forwardPorts": [5000],
  "postStartCommand": "flask run --host=0.0.0.0 --port=5000",
  "customizations": {
    "vscode": {
      "settings": {
        "python.pythonPath": "/usr/local/bin/python"
      },
      "extensions": [
        "ms-python.python",
        "ms-python.pylint"
      ]
    }
  }
}
